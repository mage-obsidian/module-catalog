<?xml version="1.0" encoding="UTF-8"?>
<!--
    CI unit suite: pure-logic tests that run on a vanilla PHP runner without a
    Magento install. Every catalog ViewModel/Block test mocks Magento Catalog
    types, so they all run in a real Magento root (see phpunit.xml) and are
    excluded here.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
         bootstrap="src/Test/Unit/bootstrap.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         failOnWarning="true"
         failOnRisky="true">
    <testsuites>
        <testsuite name="MageObsidian Catalog Standalone Unit">
            <directory>src/Test/Unit</directory>
            <exclude>src/Test/Unit/ViewModel/ProductCardTest.php</exclude>
            <exclude>src/Test/Unit/ViewModel/ProductViewTest.php</exclude>
            <exclude>src/Test/Unit/ViewModel/LayeredSwatchTest.php</exclude>
            <exclude>src/Test/Unit/ViewModel/ProductGalleryTest.php</exclude>
            <exclude>src/Test/Unit/ViewModel/CategoryLandingTest.php</exclude>
            <exclude>src/Test/Unit/Block/CategoryTitleTest.php</exclude>
        </testsuite>
    </testsuites>
</phpunit>
